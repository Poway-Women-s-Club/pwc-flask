# Copy to `.env` in this directory (next to app.py) and fill in values.
# Restart Flask after any change.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SECRET_KEY=change-me-in-production

# Local http://localhost: leave unset (Flask uses Lax + non-Secure cookies so login works).
# Deployed: GitHub Pages (HTTPS) calling your API on another HTTPS host — set:
# SESSION_COOKIE_CROSS_SITE=1
# FLASK_ENV=production
# DATABASE_URL=sqlite:///instance/pwc.db

# Frontend origin(s) for CORS and Google OAuth redirect_uri (must match Google Cloud Console).
# FRONTEND_URL=http://localhost:4600
# For GitHub Pages + deployed API, add the Pages origin:
# CORS_EXTRA_ORIGINS=https://poway-women-s-club.github.io

# SMTP — required for “reminder setup” emails and 30‑minute reminders (Gmail example).
# Use an App Password: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=youraddress@gmail.com
